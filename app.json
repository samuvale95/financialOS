{
  "expo": {
    "name": "FinancialOS",
    "slug": "financialos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0B0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.financialos.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0B0F"
      },
      "package": "com.financialos.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0B0F"
        }
      ],
      "expo-asset",
      "expo-secure-store"
    ],
    "scheme": "financialos",
    "experiments": {
      "typedRoutes": true
    }
  }
}
